{
  "name": "The-Murder-Express",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Packages": {
        "$path": "Packages"
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      },
      "ServerPackages": {
        "$path": "ServerPackages"
      }
    },

    "ServerStorage": {
      "$path": "src/server_storage",
      "$ignoreUnknownInstances": true,
      "CarModels" : {
        "$className": "Folder",
        "$ignoreUnknownInstances": true
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "PlayerModule": {
          "$path": "src/starter_player/PlayerModule"
        },
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}